
---

# .gitignore (básico)

```gitignore
# dependencies
node_modules/

# next.js
.next/
out/

# production
build/
dist/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables
.env
.env.local
.env.development.local
.env.production.local
.env.test.local

# prisma
prisma/dev.db
prisma/dev.db-journal

# coverage
coverage/

# vscode
.vscode/

# macOS
.DS_Store

# windows
Thumbs.db

# temporary files
*.tmp
*.temp

# generated
*.log

# local database dumps
*.sql
*.sqlite
*.db

# vercel / azure temp
.vercel/
.azure/